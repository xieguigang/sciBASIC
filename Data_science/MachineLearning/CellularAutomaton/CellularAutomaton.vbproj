<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
    <RootNamespace>Microsoft.VisualBasic.MachineLearning.CellularAutomaton</RootNamespace>
    <AssemblyName>Microsoft.VisualBasic.MachineLearning.CellularAutomaton</AssemblyName>
    <Platforms>AnyCPU;x64;x86</Platforms>
    <PackageRequireLicenseAcceptance>true</PackageRequireLicenseAcceptance>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <Configurations>Debug;Release;LipidSearch;Rsharp_app_release;PlantMAT;mzkit;NPSearch;mzkit_win32;gcmodeller_desktop;CFD_win32;nuget_release;Desktop;MEMI-Desktop;CellaLAB-Desktop</Configurations>
    <TargetFrameworks>net10.0</TargetFrameworks>
  </PropertyGroup>

	<ItemGroup>
	  <ProjectReference Include="..\..\..\Microsoft.VisualBasic.Core\src\Core.vbproj" />
	  <ProjectReference Include="..\..\Graph\graph-netcore5.vbproj" />
	  <ProjectReference Include="..\..\Mathematica\Math\Math\Math.NET5.vbproj" />
	</ItemGroup>
  
</Project>
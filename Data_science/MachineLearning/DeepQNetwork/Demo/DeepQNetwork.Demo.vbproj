<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>DeepQNetwork.Demo</RootNamespace>
    <AssemblyName>DeepQNetwork.Demo</AssemblyName>
    <TargetFramework>net10.0-windows</TargetFramework>
    <OutputType>WinExe</OutputType>
    <UseWindowsForms>true</UseWindowsForms>
    <UseApplicationFramework>false</UseApplicationFramework>
    <StartupObject>DeepQNetwork.Demo.Program</StartupObject>
    <Platforms>AnyCPU;x64</Platforms>
    <OptionInfer>On</OptionInfer>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <Nullable>disable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DeepQNetwork.vbproj" />
    <ProjectReference Include="..\..\..\gr\physics\physics-netcore5.vbproj" />
    <ProjectReference Include="..\..\..\Microsoft.VisualBasic.Core\src\Core.vbproj" />
    <ProjectReference Include="..\..\..\Data_science\Mathematica\Math\Math\Math.NET5.vbproj" />
    <ProjectReference Include="..\..\DeepLearning\DeepLearning.NET6.vbproj" />
    <ProjectReference Include="..\MachineLearning\machine_learning-netcore5.vbproj" />
  </ItemGroup>

</Project>

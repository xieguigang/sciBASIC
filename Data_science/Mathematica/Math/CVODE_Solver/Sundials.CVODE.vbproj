
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Microsoft.VisualBasic.Math.Sundials.CVODE</RootNamespace>
    <AssemblyName>Microsoft.VisualBasic.Math.Sundials.CVODE</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <OptionExplicit>On</OptionExplicit>
    <OptionCompare>Binary</OptionCompare>
    <OptionStrict>On</OptionStrict>
    <OptionInfer>On</OptionInfer>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
      
    <!-- 包信息 -->
    <PackageId>Sundials.CVODE.NET</PackageId>
    <Version>1.0.0</Version>
    <Authors>Your Name</Authors>
    <Description>VB.NET实现的Sundials CVODE常微分方程求解器</Description>
    <PackageTags>ODE;CVODE;Sundials;Differential-Equations;Numerical-Methods;VB.NET</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>PROJECT_SUMMARY.md</PackageReadmeFile>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <PackageRequireLicenseAcceptance>True</PackageRequireLicenseAcceptance>
    <IncludeSymbols>True</IncludeSymbols>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="test\**" />
    <EmbeddedResource Remove="test\**" />
    <None Remove="test\**" />
  </ItemGroup>

  <ItemGroup>
    <None Update="PROJECT_SUMMARY.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>


</Project>

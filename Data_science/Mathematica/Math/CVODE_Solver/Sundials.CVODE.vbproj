
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Sundials.CVODE</RootNamespace>
    <AssemblyName>Sundials.CVODE</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <OptionExplicit>On</OptionExplicit>
    <OptionCompare>Binary</OptionCompare>
    <OptionStrict>On</OptionStrict>
    <OptionInfer>On</OptionInfer>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
      
    <!-- 包信息 -->
    <PackageId>Sundials.CVODE.NET</PackageId>
    <Version>1.0.0</Version>
    <Authors>Your Name</Authors>
    <Description>VB.NET实现的Sundials CVODE常微分方程求解器，不依赖第三方库</Description>
    <PackageTags>ODE;CVODE;Sundials;Differential-Equations;Numerical-Methods;VB.NET</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="test\**" />
    <EmbeddedResource Remove="test\**" />
    <None Remove="test\**" />
  </ItemGroup>


</Project>

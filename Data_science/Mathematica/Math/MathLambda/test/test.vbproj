<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
    <TargetFrameworks>net10.0</TargetFrameworks>
    <Configurations>Debug;Release;Rsharp_app_release;LipidSearch;mzkit_win32;gcmodeller_desktop;nuget_release</Configurations>
    <Platforms>AnyCPU;x64</Platforms>
	</PropertyGroup>

	<ItemGroup>
	  <ProjectReference Include="..\..\..\..\..\Microsoft.VisualBasic.Core\src\Core.vbproj" />
	  <ProjectReference Include="..\..\..\..\..\mime\application%xml\xml-netcore5.vbproj" />
	  <ProjectReference Include="..\..\Math\Math.NET5.vbproj" />
	  <ProjectReference Include="..\symbolic-netcore5.vbproj" />
	</ItemGroup>

	<!-- Both Module1 and SymbolicTest declare a Main; pick SymbolicTest so the
	     verification examples run. -->
	<PropertyGroup>
	  <StartupObject>test.SymbolicTest</StartupObject>
	  <OutputType>Exe</OutputType>
	</PropertyGroup>
</Project>
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>Expression3DPlotter</RootNamespace>
    <AssemblyName>Expression3DPlotter</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <EnableDefaultApplicationDefinition>false</EnableDefaultApplicationDefinition>
    <OptionStrict>Off</OptionStrict>
    <OptionInfer>On</OptionInfer>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <Nullable>disable</Nullable>
    <Platforms>AnyCPU;x64</Platforms>
    <NoWarn>$(NoWarn);WFO1000</NoWarn>
    <UseWPF>True</UseWPF>
    <StartupObject>Expression3DPlotter.MainForm</StartupObject>
    <MyType>WindowsFormsWithCustomSubMain</MyType>
    <NoWarn>$(NoWarn);WFO1000</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Import Include="System.Windows.Forms" />
    <Import Include="System.Drawing" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\gr\Microsoft.VisualBasic.Imaging\imaging.NET5.vbproj" />
    <ProjectReference Include="..\..\Mathematica\Math\Math\Math.NET5.vbproj" />
    <ProjectReference Include="..\..\DataPlot\DataPlot.vbproj" />
    <ProjectReference Include="..\..\..\Microsoft.VisualBasic.Core\src\Core.vbproj" />
    <ProjectReference Include="..\..\..\mime\text%html\html_netcore5.vbproj" />
    <ProjectReference Include="..\..\..\gr\Drawing-net4.8\Drawing-net4.8.vbproj" />
  </ItemGroup>

</Project>

<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <library_geometries>
    <geometry id="cube" name="cube">
      <mesh>
        <source id="cube-pos">
          <float_array id="cube-pos-array" count="24">
            -0.5 -0.5 -0.5
            -0.5  0.5 -0.5
             0.5  0.5 -0.5
             0.5 -0.5 -0.5
            -0.5 -0.5  0.5
            -0.5  0.5  0.5
             0.5  0.5  0.5
             0.5 -0.5  0.5
          </float_array>
          <technique_common>
            <accessor source="#cube-pos-array" count="8" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>
        <vertices id="cube-vtx">
          <input semantic="POSITION" source="#cube-pos"/>
        </vertices>
        <triangles material="Material" count="12">
          <p>
            0 1 2  0 2 3
            4 6 5  4 7 6
            0 4 5  0 5 1
            1 5 6  1 6 2
            2 6 7  2 7 3
            3 7 4  3 4 0
          </p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>
</COLLADA>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Microsoft.VisualBasic.Imaging.Physics</RootNamespace>
    <TargetFrameworks>net10.0-windows</TargetFrameworks>
    <AssemblyName>Microsoft.VisualBasic.Imaging.Physics</AssemblyName>
    <Platforms>AnyCPU;x64</Platforms>
    <Configurations>Debug;Release;LipidSearch;Rsharp_app_release;mzkit;NPSearch;gcmodeller_desktop;CFD_win32;nuget_release;CellaLAB-Desktop</Configurations>
    <GeneratePackageOnBuild>False</GeneratePackageOnBuild>
    <PackageIcon>logo-knot.png</PackageIcon>
    <AutoGenerateBindingRedirects>True</AutoGenerateBindingRedirects>
    <GenerateDocumentationFile>True</GenerateDocumentationFile>
    <PackageProjectUrl>http://scibasic.net</PackageProjectUrl>
    <RepositoryUrl>https://github.com/xieguigang/sciBASIC</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <UseApplicationFramework>True</UseApplicationFramework>
    <OutputType>WinExe</OutputType>
    <UseWindowsForms>True</UseWindowsForms>
    <UseWPF>True</UseWPF>
    <StartupObject>Microsoft.VisualBasic.Imaging.Physics.Form3</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Data_science\Graph\graph-netcore5.vbproj" />
    <ProjectReference Include="..\..\..\Data_science\Mathematica\Math\Math\Math.NET5.vbproj" />
    <ProjectReference Include="..\..\..\Microsoft.VisualBasic.Core\src\Core.vbproj" />
    <ProjectReference Include="..\..\..\mime\text%html\html_netcore5.vbproj" />
    <ProjectReference Include="..\..\Drawing-net4.8\Drawing-net4.8.vbproj" />
    <ProjectReference Include="..\..\Microsoft.VisualBasic.Imaging\imaging.NET5.vbproj" />
    <ProjectReference Include="..\physics-netcore5.vbproj" />
  </ItemGroup>
</Project>